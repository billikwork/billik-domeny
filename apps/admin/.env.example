# Required — login password for admin panel
ADMIN_PASSWORD=your-strong-password-here

# Optional — separate signing secret (defaults to ADMIN_PASSWORD)
ADMIN_SESSION_SECRET=

# GitHub publish (required on Vercel production)
GITHUB_TOKEN=
GITHUB_OWNER=billikwork
GITHUB_REPO=billik-domeny
GITHUB_BRANCH=main

# Optional — one URL for the whole sites app (not a list of domains).
# Defaults to https://billik-domeny-sites-ehy9.vercel.app in production.
# NEXT_PUBLIC_SITES_PREVIEW_URL=https://billik-domeny-sites-ehy9.vercel.app